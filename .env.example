# PostgreSQL (n8n backing store)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n

# n8n
N8N_ENCRYPTION_KEY=generate_a_random_32_char_string
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=America/New_York

# WAHA (self-hosted WhatsApp API)
WAHA_API_KEY=change_me

# Ollama
OLLAMA_MODEL=llama3.2-vision:11b

# Google APIs (configure OAuth2 credentials inside the n8n UI instead of here;
# these are just for reference / non-n8n scripts)
GOOGLE_SHEETS_ID=your_google_sheet_id
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id

# Approver's WhatsApp number (E.164 format, no + or spaces), e.g. 15551234567
APPROVER_WHATSAPP_NUMBER=15551234567
